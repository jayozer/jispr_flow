# local-flow configuration (all values optional; defaults shown).
# Copy to .env, or export these variables, or use local-flow.toml (see README).
# Precedence: environment variables > config file > defaults.

# --- LM Studio (OpenAI-compatible local server; used for polish + command mode) ---
# Base URL of the LM Studio local server. Must stay local-first; cloud AI hosts are refused.
LOCAL_FLOW_LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Model identifier as shown in LM Studio. Leave empty to auto-pick the first loaded model.
LOCAL_FLOW_LMSTUDIO_MODEL=
# Request timeout in seconds.
LOCAL_FLOW_LMSTUDIO_TIMEOUT=60

# --- ASR (local speech-to-text; LM Studio is NOT used for ASR) ---
# Backend: faster-whisper | mock
LOCAL_FLOW_ASR_BACKEND=faster-whisper
# faster-whisper model name or a path to a local CTranslate2 model directory.
# Names like "base.en"/"small.en" are downloaded once and cached locally.
LOCAL_FLOW_ASR_MODEL=small.en
# Device: auto | cpu | cuda
LOCAL_FLOW_ASR_DEVICE=auto
# Compute type: int8 (CPU-friendly) | float16 | float32
LOCAL_FLOW_ASR_COMPUTE_TYPE=int8
# Recognition language: en (default) | ISO 639-1 code (fr, de, ...) | auto
# (detect per utterance). Non-"en" values require a multilingual model
# (e.g. "small"), not an English-only ".en" model.
LOCAL_FLOW_ASR_LANGUAGE=en

# --- VAD (voice activity detection for hands-free mode) ---
# Backend: energy (pure Python, no extra deps) | webrtc | mock
LOCAL_FLOW_VAD_BACKEND=energy
# WebRTC VAD aggressiveness, 0 (least) to 3 (most aggressive).
LOCAL_FLOW_VAD_AGGRESSIVENESS=2
# Frame size in milliseconds (WebRTC VAD supports 10, 20, or 30).
LOCAL_FLOW_VAD_FRAME_MS=30
# Silence duration (ms) that closes an utterance in hands-free mode.
LOCAL_FLOW_VAD_SILENCE_MS=600
# RMS threshold for the energy VAD backend (int16 PCM scale).
LOCAL_FLOW_VAD_ENERGY_THRESHOLD=500

# --- Hotkey / capture mode ---
# Mode: push-to-talk | hands-free
LOCAL_FLOW_MODE=push-to-talk
# Push-to-talk key: fn (macOS only; the default there) | space (hold to
# dictate, tap types a space; macOS/Windows) | any pynput key name (f9, f8,
# scroll_lock, ...). Default: fn on macOS, f9 elsewhere. Left unset/commented
# here so the file works unmodified on every platform.
# LOCAL_FLOW_HOTKEY=fn
# Hold threshold (ms) separating "tap = type a space" from "hold = dictate".
LOCAL_FLOW_HOTKEY_SPACE_HOLD_MS=250
# Key that discards an in-flight dictation (pynput key name; the fn hotkey
# supports only esc).
LOCAL_FLOW_CANCEL_HOTKEY=esc

# --- Style / personalization ---
# Active style rule set name (defined in styles.json in the data dir).
LOCAL_FLOW_STYLE=default
# Directory holding dictionary.json, snippets.json, styles.json.
LOCAL_FLOW_DATA_DIR=~/.local/share/local-flow

# --- Tray app (`local-flow tray`; requires: uv sync --extra tray) ---
# Comma-separated ISO 639-1 codes for the tray's Language quick-switch menu
# (e.g. "en,de,fr"). Leave empty to hide that menu entirely. Switching
# languages needs a multilingual ASR model (see LOCAL_FLOW_ASR_MODEL above).
LOCAL_FLOW_LANGUAGES=

# --- Per-app context (frontmost app -> style/insert overrides; see README) ---
# Set to false to ignore app_styles.json and never query the frontmost app.
LOCAL_FLOW_CONTEXT_STYLES=true

# --- Text insertion ---
# Method: auto (paste, then type, then clipboard-only) | paste | type | clipboard
LOCAL_FLOW_INSERT_METHOD=auto

# --- Audio ---
LOCAL_FLOW_SAMPLE_RATE=16000

# --- Dictation history (local JSONL log at <data dir>/history.jsonl) ---
# Set to false to stop recording dictations (existing history stays readable).
LOCAL_FLOW_HISTORY_ENABLED=true
# Rotate out the oldest entries once the file exceeds this many records.
LOCAL_FLOW_HISTORY_MAX_ENTRIES=5000
# Retention policy: forever (keep everything) | 24h (prune on each write) | off (never write)
LOCAL_FLOW_HISTORY_RETENTION=forever

# --- Streaming / low-latency insertion (hands-free mode only; see README "Streaming") ---
# off (default) | sentence (insert each sentence while the next is still
# being spoken) | live-preview (rough partial text shown while speaking;
# final insert unchanged). Ignored (with a one-line notice) in push-to-talk.
LOCAL_FLOW_STREAMING=off
# In "sentence" mode, the pause (ms) that closes one chunk and lets it
# insert while you keep talking. Shorter = lower latency but more
# risk of splitting mid-sentence; only used when LOCAL_FLOW_STREAMING=sentence.
LOCAL_FLOW_STREAMING_PAUSE_MS=300
